	itemDef {
		cvarTest "r_ignorehwgamma"
		showcvar { "1" }

		name graphics
		group grpSystem
		type ITEM_TYPE_SLIDER
		text "UI_GRAPHICS_BRIGHTNESS"
		cvarfloat "r_gamma" 1.3 .5 3
		rect 82 235 290 12
      	textalign ITEM_ALIGN_RIGHT
      	textalignx 142 
      	textaligny 10
		textscale .23 
		style WINDOW_STYLE_FILLED
		backcolor 1 1 1 .07       
