	itemDef {
		name graphics
		group grpSystem
		type ITEM_TYPE_MULTI
		text "UI_GRAPHICS_FTEXTURES"
		cvar "r_texturemode"
		cvarStrList { "UI_GRAPHICS_BILINEAR", "GL_LINEAR_MIPMAP_NEAREST", "UI_GRAPHICS_TRILINEAR", "GL_LINEAR_MIPMAP_LINEAR"  }
		rect 82 190 290 12
